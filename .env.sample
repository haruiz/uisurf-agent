# UISurf agent runtime configuration

# At least one provider key must be set for Gemini / Google model access.
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Default model used by the agent runtime.
MODEL_ID=gemini-2.5-flash

# A2A server bind configuration.
AGENT_HOST=0.0.0.0
BROWSER_AGENT_PORT=8001
DESKTOP_AGENT_PORT=8002

# Public URLs advertised by the A2A server when running in Docker.
BROWSER_AGENT_PUBLIC_URL=http://localhost:6080/browser/
DESKTOP_AGENT_PUBLIC_URL=http://localhost:6080/desktop/

# Optional container/VNC configuration used by the packaged runtime.
PASSWORD_REQUIRED=false
